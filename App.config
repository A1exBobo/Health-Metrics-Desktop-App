<configuration>
	<connectionStrings>
		<add name="MyDb"
			 connectionString="Data Source=(LocalDB)\MSSQLLocalDB;
                           AttachDbFilename=|DataDirectory|\MyDatabase.mdf;
                           Integrated Security=True;
                           Connect Timeout=30;"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>